# DeployUnit backend configuration. Copy to .env for local dev, or set these
# as environment variables on your host. See DEPLOY.md.

# --- Core ---
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=deployunit
JWT_SECRET=change-me-48-random-chars
ENCRYPTION_KEY=change-me-fernet-key
DEPLOYUNIT_ENV=production
FRONTEND_URL=https://app.deployunit.com
CORS_ORIGINS=*

# --- Build engine (Coolify) ---
COOLIFY_BASE_URL=http://your-coolify-host:8000
COOLIFY_API_TOKEN=
COOLIFY_SERVER_UUID=

# --- WHMCS / ServUnit integration ---
# Enables POST /api/internal/* (provisioning). Unset = the internal API is off.
INTERNAL_API_KEY=
# Shows the "Continue with ServUnit" button + hands off to the WHMCS launcher.
WHMCS_LOGIN_URL=

# --- Optional integrations ---
MOLLIE_API_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_PAGESPEED_API_KEY=
INVOICE_STORAGE_PATH=/app/storage/invoices

# --- Scaling ---
# Set to 1 on web replicas when a separate worker.py owns the scheduler.
# DISABLE_SCHEDULER=1
